rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isDriver() {
      return isAuthenticated() && getUserData().role == 'driver';
    }

    // ===============================================================
    // User Profiles
    // ===============================================================
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // ===============================================================
    // Parcels
    // ===============================================================
    match /parcels/{parcelId} {
      
      // Users can read their own parcels. Drivers can read all parcels.
      allow read: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid || isDriver()
      );

      // Only authenticated users can create parcels, and they must set themselves as owner.
      allow create: if isAuthenticated() && 
        request.resource.data.ownerId == request.auth.uid &&
        request.resource.data.status == 'pending' &&
        request.resource.data.destinationArea is string &&
        !('deliveryUID' in request.resource.data);

      // Update logic
      allow update: if isAuthenticated() && (
        // 1. Owner can update their own parcel (e.g., to cancel or edit details)
        // but they cannot change the deliveryUID or status once it's accepted by someone else.
        (isOwner(resource.data.ownerId) && 
         request.resource.data.ownerId == request.auth.uid &&
         (!('deliveryUID' in resource.data) || resource.data.deliveryUID == null)) ||
        
        // 2. Driver can accept a pending parcel
        (isDriver() && 
         resource.data.status == 'pending' &&
         request.resource.data.status == 'accepted' &&
         request.resource.data.deliveryUID == request.auth.uid &&
         // Ensure other fields remain unchanged
         request.resource.data.ownerId == resource.data.ownerId &&
         request.resource.data.deliveryCompany == resource.data.deliveryCompany &&
         request.resource.data.destinationArea == resource.data.destinationArea &&
         request.resource.data.receiverName == resource.data.receiverName
        ) ||

        // 3. Assigned driver can mark as delivered
        (isDriver() &&
         resource.data.deliveryUID == request.auth.uid &&
         resource.data.status == 'accepted' &&
         request.resource.data.status == 'delivered' &&
         // Ensure other fields remain unchanged
         request.resource.data.ownerId == resource.data.ownerId &&
         request.resource.data.deliveryUID == resource.data.deliveryUID
        )
      );

      // Delete logic
      allow delete: if isOwner(resource.data.ownerId) && 
        (!('deliveryUID' in resource.data) || resource.data.deliveryUID == null);
    }
  }
}
